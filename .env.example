# ── AKGYS ortam değişkenleri ──────────────────────────────────────
# Kullanım: bu dosyayı `.env` olarak kopyalayıp değerleri doldurun,
#   `set -a; source .env; set +a` ile yükleyin, sonra uygulamayı çalıştırın.

# ── Pi sunucusu (pi_server/app.py) ───────────────────────────────
AKGYS_HOST=0.0.0.0
AKGYS_PORT=5001
# Boş bırakılırsa her başlangıçta rastgele üretilir (oturumlar arası kalıcı değil).
AKGYS_SECRET_KEY=
# Üretimde tek tek origin verin, örn: http://10.126.14.177:5001
AKGYS_CORS=*
# Ekran görüntüsü uç noktası: token BOŞSA uç nokta tamamen kapalıdır.
AKGYS_SCREENSHOT_TOKEN=
AKGYS_SCREENSHOT_DIR=~/akgys/screenshots
AKGYS_LOG_DIR=~/akgys/logs
AKGYS_ROUTE_KM=1900
AKGYS_ROUTE_MIN=83
AKGYS_DEMO_MULT=35
AKGYS_OVERRIDE_HOLD=18

# ── Mac asistanı (mac_assistant/assistant.py) ────────────────────
AKGYS_PI_URL=http://10.126.14.177:5001
AKGYS_OLLAMA_URL=http://localhost:11434
AKGYS_OLLAMA_MODEL=qwen2.5:3b
AKGYS_WHISPER_MODEL=small
AKGYS_SAMPLE_RATE=16000
# Boş = sistem varsayılan mikrofon; sayı = cihaz index'i; metin = cihaz adı
AKGYS_MIC_DEVICE=
# VAD ayarları (gürültülü ortamda vad_factor'ı artırın)
AKGYS_VAD_FACTOR=3.5
AKGYS_VAD_SILENCE_MS=800
AKGYS_UTTER_MAX_S=12
AKGYS_START_TIMEOUT_S=8
AKGYS_ACTIVE_WINDOW_S=12
AKGYS_CONFIRM_TIMEOUT_S=6
# TTS
AKGYS_TTS_VOICE=Yelda
AKGYS_TTS_RATE=180
AKGYS_TTS_DEVICE=
# LLM
AKGYS_LLM_TIMEOUT=20
AKGYS_LLM_NUM_PREDICT=200
AKGYS_LLM_TEMPERATURE=0.6
AKGYS_MEMORY_TURNS=4
